# ============================================================
# MTSPC26 — Variables d'environnement Backend
# Copiez ce fichier en ".env" et remplissez vos valeurs
# NE JAMAIS committer le fichier .env dans Git
# ============================================================

# --- Serveur ---
PORT=9090
NODE_ENV=development

# --- Base de données PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=mtspc26_user
DB_PASSWORD=VotreMotDePasseIci
DB_NAME=mtspc26_logistique

# --- Keycloak (Serveur d'Authentification) ---
# URL du serveur Keycloak
KEYCLOAK_SERVER=http://localhost:8180

# Nom du Realm créé à l'étape 1
KEYCLOAK_REALM=Logistique

# Client ID confidentiel (logistique-api) — Étape 3
KEYCLOAK_CLIENT_ID=logistique-api

# Secret récupéré dans Clients > logistique-api > Credentials
KEYCLOAK_CLIENT_SECRET=VOTRE_SECRET_ICI

# URL JWKS : Keycloak publie ses clés publiques ici automatiquement
# Format : {KEYCLOAK_SERVER}/realms/{KEYCLOAK_REALM}/protocol/openid-connect/certs
KEYCLOAK_JWKS_URI=http://localhost:8180/realms/Logistique/protocol/openid-connect/certs

# Issuer : doit correspondre exactement à ce que Keycloak met dans le JWT
KEYCLOAK_ISSUER=http://localhost:8180/realms/Logistique

# --- CORS (Frontend Web) ---
FRONTEND_URL=http://localhost:3000
